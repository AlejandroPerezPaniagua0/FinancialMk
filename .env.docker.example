# FinancialMk · Docker Compose environment
#
# Copy this file to .env.docker and edit as needed:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up
#
# Or just rely on the safe defaults below by running:
#   cp .env.docker.example .env
#   docker compose up

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_PORT=8080
LOG_LEVEL=info

# Generate one with: docker compose run --rm back php artisan key:generate --show
# Or leave blank on first boot — the container entrypoint will generate it.
APP_KEY=

# ── Database (Postgres in compose) ────────────────────────────────────────
DB_DATABASE=financialmk
DB_USERNAME=financialmk
DB_PASSWORD=financialmk

# ── Market data provider ──────────────────────────────────────────────────
# Choose one: stooq (free, no key), twelve_data (freemium, needs key)
MARKET_PROVIDER=stooq

# Only required if MARKET_PROVIDER=twelve_data. Get a free key at
# https://twelvedata.com — free tier is 8 req/min.
TWELVE_DATA_API_KEY=

# Polling tuning. Defaults are tuned for free tiers.
MARKET_POLLING_THROTTLE_SECONDS=30
MARKET_POLLING_MAX_ASSETS=4
MARKET_POLLING_REQUEST_RATE=30,1

# ── Demo mode ─────────────────────────────────────────────────────────────
# When true, /demo lets visitors try the app without registering, with a
# pre-armed watchlist. Safe to leave on for self-hosted demos and learning.
DEMO_MODE=true

# ── Mail ──────────────────────────────────────────────────────────────────
# log = write mails to laravel.log; useful for local dev.
# To wire SMTP for price alerts, add MAIL_HOST/USERNAME/PASSWORD here and
# set MAIL_MAILER=smtp.
MAIL_MAILER=log
